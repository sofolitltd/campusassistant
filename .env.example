# ─── API URL ────────────────────────────────────────────
# Production:
BASE_URL=https://campusassistant.duckdns.org/api/v1
# Local development (emulator):
# BASE_URL=http://10.0.2.2:8080/api/v1
# Neon (Vercel):
# BASE_URL=https://campusassistant-api.vercel.app/api/v1

# ─── API Key (X-API-Key header) ────────────────────────
API_KEY=change-this-to-your-api-key

# ─── bKash Production Credentials ──────────────────────
# BKASH_PROD_USERNAME=your-production-username
# BKASH_PROD_PASSWORD=your-production-password
# BKASH_PROD_APP_KEY=your-production-app-key
# BKASH_PROD_APP_SECRET=your-production-app-secret

# ─── bKash Sandbox Credentials (optional overrides) ────
# BKASH_SANDBOX_USERNAME=sandboxTokenizedUser02
# BKASH_SANDBOX_PASSWORD=sandboxTokenizedUser02@12345
# BKASH_SANDBOX_APP_KEY=4f6o0cjiki2rfm34kfdadl1eqq
# BKASH_SANDBOX_APP_SECRET=2is7hdktrekvrbljjh44ll3d9l1dtjo4pasmjvs5vl5qr3fug4b
